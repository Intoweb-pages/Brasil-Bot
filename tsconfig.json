{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["es2022"],
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts"]
}
